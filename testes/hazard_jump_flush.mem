# Teste 5: Jump Flush
#
# [0] addi $r1, $r0, 5  →  opcode=0100 rs=000 rt=001 imm=000101(5)
# [1] j 3               →  opcode=0010 addr=000000000011(3) → salta para inst[3]
#                            instrucao em IF ($r2) deve ser descartada (flush)
# [2] addi $r2, $r0, 99 →  DESCARTADA (flush)
# [3] addi $r3, $r0, 8  →  destino do jump, $r3=8
#
# Esperado: $r1=5, $r2=0, $r3=8  |  stalls=0, forwards=0, flushes=1
0100000001000101
0010000000000011
0100000010001100
0100000011001000
